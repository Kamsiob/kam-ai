<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The only permission in the app. It is needed to download a model, a
         voice, or a content pack, and for opt-in web search. Nothing is sent
         anywhere on its own, and nothing is fetched in the background.

         Every permission here has to be earned by a feature that exists.
         WorkManager was removed for exactly this reason: nothing used it, and
         it silently added RECEIVE_BOOT_COMPLETED, WAKE_LOCK and
         FOREGROUND_SERVICE to the merged manifest. An app that promises it only
         touches the network when asked should not also be asking to start
         itself at boot. See DECISIONS.md. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Downloads keep running while the app is in the background, through a
         foreground service that shows a progress notification. Added deliberately
         because model downloads are large and a user should not have to keep the
         app open for twenty minutes. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Voice typing transcribes on-device with whisper.cpp. Requested only at
         first use, and the microphone is not required to install the app. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- arm64 with the NEON extensions the model runtime is built against. -->
    <uses-feature android:name="android.hardware.ram.normal" android:required="false" />

    <application
        android:name=".KamApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.KamAI">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.KamAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The share sheet still targets MainActivity for shared text below; this
             dedicated activity handles the text-selection "Ask Kam AI" action and
             the share sheet through one lightweight sheet. Zero permissions. -->
        <activity
            android:name=".integrations.TextIntakeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.KamAI.Overlay">
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Home-screen widget: new chat or voice. Zero permissions. -->
        <receiver
            android:name=".integrations.KamWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/kam_widget_info" />
        </receiver>

        <!-- Quick-settings tile: jump into a new chat. -->
        <service
            android:name=".integrations.KamTileService"
            android:exported="true"
            android:icon="@drawable/ic_splash_mark"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- The quick assistant overlay, opened by the assist gesture. Its own
             transparent, floating window over other apps; kept out of Recents. -->
        <activity
            android:name=".assist.OverlayActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:taskAffinity=".assist.overlay"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.KamAI.Overlay" />

        <!-- Digital assistant registration (ROLE_ASSISTANT). See
             res/xml/kam_assist.xml for how the three services tie together. -->
        <service
            android:name=".assist.KamAssistService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/kam_assist" />
        </service>

        <service
            android:name=".assist.KamAssistSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <service
            android:name=".assist.KamRecognitionService"
            android:exported="true"
            android:permission="android.permission.RECORD_AUDIO">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/kam_recognition" />
        </service>

        <!-- Keeps downloads alive in the background with a progress notification. -->
        <service
            android:name=".download.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
