<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/widget_text"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/widget_new_chat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New chat"
        android:gravity="center"
        android:textColor="@color/widget_on_accent"
        android:textSize="14sp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:background="@drawable/widget_pill_accent"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/widget_voice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Talk to it"
        android:gravity="center"
        android:textColor="@color/widget_text"
        android:textSize="14sp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:background="@drawable/widget_pill_surface" />
</LinearLayout>
